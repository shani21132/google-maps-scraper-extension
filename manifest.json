{
  "manifest_version": 3,
  "name": "ZR Maps Scraper",
  "version": "3.0",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["maps_content.js"]
    }
  ]
}